{
  "name": "@beyondtrust/workload-credentials",
  "version": "0.0.0",
  "private": true,
  "description": "A typescript action to get secrets from workload credentials",
  "scripts": {
    "build": "tsx ./build.ts",
    "format": "prettier --write \"**/*.{ts,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,yaml,yml}\"",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "all": "npm run format && npm run lint && npm test && npm run build"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "BeyondTrust",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/http-client": "^4.0.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@beyondtrust/prettier-configuration": "^1.0.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "prettier": "@beyondtrust/prettier-configuration"
}
