{
  "name": "@beyondtrust/workload-credentials-action",
  "version": "1.0.1",
  "private": true,
  "description": "Securely retrieve secrets from BeyondTrust Workload Credentials in your GitHub Actions workflows via OIDC",
  "scripts": {
    "build": "tsx ./build.ts",
    "format": "prettier --write \"**/*.{ts,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,yaml,yml}\"",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "all": "npm run format:check && npm run lint && npm test && npm run build"
  },
  "keywords": [
    "github-actions",
    "beyondtrust",
    "secrets",
    "security",
    "devops",
    "continuous-integration",
    "utilities",
    "oidc"
  ],
  "author": "BeyondTrust Corporation",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/http-client": "^4.0.1",
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.4"
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "undici": "6.27.0",
    "esbuild": "0.28.1",
    "@babel/core": "7.29.7"
  }
}
