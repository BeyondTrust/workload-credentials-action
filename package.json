{
  "name": "@beyondtrust/{{ template.name }}",
  "version": "0.0.0",
  "private": true,
  "description": "{{ template.description }}",
  "scripts": {
    "build": "tsx ./build.ts",
    "format": "prettier --write \"**/*.{ts,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,yaml,yml}\"",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "all": "npm run format && npm run lint && npm test && npm run build"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "BeyondTrust",
  "dependencies": {
    "@actions/core": "^1.11.1"
  },
  "devDependencies": {
    "@beyondtrust/prettier-configuration": "^1.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.1",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^9.28.0",
    "eslint-plugin-jest": "^28.13.3",
    "jest": "^30.0.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.0",
    "tsx": "^4.20.2",
    "typescript": "^5.8.3"
  },
  "prettier": "@beyondtrust/prettier-configuration"
}
